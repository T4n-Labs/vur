# Template file for 'tpm'
pkgname=tpm
version=0.0.1
revision=1
build_style=meta
short_desc="A user-friendly package manager wrapper for XBPS"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="MIT"
homepage="https://github.com/T4n-Labs/TPM"
distfiles="https://github.com/T4n-Labs/TPM/archive/refs/tags/${version}.tar.gz"
checksum=91017ff6c144e749cf57a4259de3e8125031c77c0b7260326385b53d6729a7c3

depends="xbps"

do_install() {
    vinstall tpm 755 usr/bin

    vinstall lib/core.sh 644 usr/lib/tpm/lib
    vinstall lib/ui.sh   644 usr/lib/tpm/lib

    for cmd in install remove search update upgrade; do
        vinstall commands/${cmd}.sh 755 usr/lib/tpm/commands
    done

    vinstall config 644 etc/tpm.conf
}
