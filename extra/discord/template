# Template file for 'discord'
# This template is old
pkgname=discord
version=0.0.134
revision=1
archs="x86_64"
depends="alsa-lib dbus-glib gtk+3 libnotify nss libXtst libcxx libatomic xdg-utils webrtc-audio-processing libXScrnSaver xdg-desktop-portal xdg-desktop-portal-gtk"
short_desc="Chat and VOIP application"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="Proprietary"
homepage="https://discord.com"
distfiles="https://dl.discordapp.net/apps/linux/${version}/discord-${version}.tar.gz"
checksum=37881d723f0b6225f1be46d9859ca25abdfbe6f697b7a267c1ca2a2ce28cb068
repository=nonfree
restricted=yes
nopie=yes
nostrip=yes

do_install() {
    local dir="usr/lib/discord"

    # Copy semua hasil extract
    vmkdir ${dir}
    vcopy * ${dir}

    # Fix permission binary
    chmod +x ${DESTDIR}/${dir}/Discord

    # Fix sandbox (biar gak crash di Void minimal)
    chown root:root ${DESTDIR}/${dir}/chrome-sandbox
    chmod 4755 ${DESTDIR}/${dir}/chrome-sandbox

    # Symlink ke command
    vmkdir usr/bin
    ln -s /usr/lib/discord/Discord ${DESTDIR}/usr/bin/discord

    # Desktop entry
    vmkdir usr/share/applications
    vinstall ${FILESDIR}/discord.desktop 644 usr/share/applications

    # Icon global
    vmkdir usr/share/pixmaps
    vinstall discord.png 644 usr/share/pixmaps/discord.png
}

post_install() {
    vlicense LICENSE
}
