# Template file for 'xvr-lang'
pkgname=xvr
version=0.6.16
revision=1
build_style=cmake
_llvm_major=22
_llvm_prefix=/usr/lib/llvm/${_llvm_major}

configure_args="
 -DCMAKE_BUILD_TYPE=Release
 -DLLVM_DIR=${_llvm_prefix}/lib/cmake/llvm
 -DLLVM_CONFIG=${_llvm_prefix}/bin/llvm-config
 -DBUILD_TESTING=OFF
"

makedepends="
 llvm${_llvm_major}
 llvm${_llvm_major}-devel
 clang${_llvm_major}
 gcc
 libxml2-devel
 libcurl-devel
"

short_desc="The XVR Programming Language Compiler By Arfy Slowy"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="MIT"
homepage="https://github.com/xvrlang/xvr"
distfiles="https://github.com/xvrlang/xvr/archive/refs/tags/${version}.tar.gz"
checksum=04f3717e3a4ded3489869af78a36c31b61d900fccc1dfd6b5195a40467a16b98

post_install() {
    # Hapus cmake test files yang salah lokasi
    rm -rf ${DESTDIR}/usr/bin/test

    # Fix binary permission
    chmod +x ${DESTDIR}/usr/bin/xvr

    # Install license
    vlicense LICENSE
}
