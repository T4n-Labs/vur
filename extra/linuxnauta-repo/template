# Template file for 'linuxnauta-repo'
pkgname=linuxnauta-repo
version=1
revision=1
short_desc="Binary repositories for Void Linux by jmboris"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="BSD-2-Clause"
homepage="https://linuxnauta.com/"
skip_extraction="COPYING"

do_install() {
	vmkdir usr/share/xbps.d

	case "$XBPS_TARGET_MACHINE" in
		aarch64)
			echo 'repository=https://voidrepo.linuxnauta.com' > \
				${DESTDIR}/usr/share/xbps.d/99-voidrepo-linuxnauta.conf
			;;
		x86_64)
			echo 'repository=https://voidrepo.linuxnauta.com' > \
				${DESTDIR}/usr/share/xbps.d/99-voidrepo-linuxnauta.conf
			;;
		*)
			msg_error "$pkgname: unsupported architecture $XBPS_TARGET_MACHINE\n"
			;;
	esac

	vlicense ${XBPS_SRCDISTDIR}/${pkgname}-${version}/COPYING
}
