# Template file for 'faugus-launcher'
pkgname=faugus-launcher
version=1.19.3
revision=1
build_style=meson
hostmakedepends="meson ninja pkg-config python3"
makedepends="libayatana-appindicator-devel libcanberra-devel"
depends="
 python3
 python3-gobject
 python3-requests
 python3-Pillow
 python3-vdf
 python3-psutil
 python3-pygame
 ImageMagick
 python3-icoextract
 libayatana-appindicator
 libcanberra
 Vulkan-Tools
"
short_desc="Game launcher for Windows games via Wine/Proton/Bottles"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="MIT"
homepage="https://github.com/Faugus/faugus-launcher"
distfiles="https://github.com/Faugus/faugus-launcher/archive/refs/tags/${version}.tar.gz"
checksum=a7cf76ef8d03978905850eb35f93265299a42b213f2f47eabecb5a23f74541da
python_version=ignore

pre_build() {
	# Hook host 04-create-xbps-metadata-scripts mencari trigger files di
	# $XBPS_SRCPKGDIR/xbps-triggers/files. Repo minimal tidak punya ini.
	# Karena XBPS_DISTDIR di-mount ke chroot, kita bisa buat symlink
	# ke common/triggers dari dalam template — tidak perlu ubah utilitas.
	if [ ! -e "${XBPS_DISTDIR}/srcpkgs/xbps-triggers/files" ]; then
		mkdir -p "${XBPS_DISTDIR}/srcpkgs/xbps-triggers"
		ln -sf ../../common/triggers "${XBPS_DISTDIR}/srcpkgs/xbps-triggers/files"
	fi
}

post_install() {
	# Hindari pycompile trigger: pindahkan modul Python ke lokasi non-standard.
	# .pth mengarahkan Python interpreter ke lokasi baru saat runtime.
	local pyver=$(python3 -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')")
	local sitepkg="${DESTDIR}/usr/lib/python${pyver}/site-packages"
	local destlib="${DESTDIR}/usr/lib/faugus-launcher/python"

	if [ -d "${sitepkg}/faugus" ]; then
		vmkdir usr/lib/faugus-launcher/python
		mv "${sitepkg}/faugus" "${destlib}/faugus"
		echo "/usr/lib/faugus-launcher/python" > "${sitepkg}/faugus-launcher.pth"
	fi
}
