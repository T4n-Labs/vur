# Template file for 'zen-browser'
pkgname=zen-browser
version=1.20.1b
revision=1
archs="x86_64"
short_desc="Performance oriented Firefox-based web browser"
maintainer="Gh0sT4n <darskevoid@gmail.com>"
license="MPL-2.0"
homepage="https://zen-browser.app/"
changelog="https://zen-browser.app/release-notes/"
distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-x86_64.tar.xz"
checksum=43fa8cde02d60b473164fd7be8ee6fc0a9f0dc071288f0456850ec56e575c09a
nostrip=yes
wrksrc="zen"

do_install() {
	# Salin seluruh isi folder zen/ ke /usr/lib/zen-browser/
	vmkdir usr/lib/zen-browser
	cp -r ${wrksrc}/. ${DESTDIR}/usr/lib/zen-browser/

	# Symlink wrapper script ke /usr/bin/zen
	vmkdir usr/bin
	ln -sf /usr/lib/zen-browser/zen ${DESTDIR}/usr/bin/zen

	# Desktop entry dan icon
	vinstall ${FILESDIR}/zen.desktop 644 usr/share/applications
	vinstall ${FILESDIR}/zen.png 644 usr/share/pixmaps
}
